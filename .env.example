# ── Dev proxy (server-side only, never sent to browser) ──────────────────────
# Target for Vite's dev-server proxy. Set to the PHP backend URL reachable
# from the Node process (i.e. the Docker service name, not localhost).
# Default when unset: http://localhost:8080
#
# In Docker Compose (shared network):   API_PROXY_TARGET=http://app:80
# Outside Docker (local npm run dev):   leave unset or set http://localhost:8080
API_PROXY_TARGET=http://app:80

# ── Production cross-origin deployments (exposed to browser) ─────────────────
# Set only when frontend and backend are served from different origins.
# Leave empty (or unset) in dev — Vite's proxy handles routing transparently.
# VITE_API_BASE=https://api.example.com
