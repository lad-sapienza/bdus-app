# BraDypUS Vue frontend environment variables (Vite)
# Copy this file to vue/.env.local and adjust for your setup.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# ── Backend base URL ─────────────────────────────────────────────────────────
# Full URL of the PHP backend, WITHOUT a trailing slash.
# Leave empty (or unset) when the frontend is served by the same server as
# the backend — all API calls will be made relative to the current origin.
#
# Set this when running the Vue dev server against a remote backend, or when
# deploying the built frontend to a different host (GitHub Pages, CDN, etc.).
#
# Examples:
#   VITE_API_BASE=http://localhost:8080          # local Docker backend
#   VITE_API_BASE=https://api.myproject.org      # production split deployment
VITE_API_BASE=
